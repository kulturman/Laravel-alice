{
    "name": "kulturman/laravel-alice",
    "description": "YAML-based fixture loading for Laravel using nelmio/alice with Eloquent persistence",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "nelmio/alice": "^3.17",
        "theofidry/alice-data-fixtures": "^1.11",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Kulturman\\LaravelAlice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kulturman\\LaravelAlice\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kulturman\\LaravelAlice\\LaravelAliceServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
